# ==============================
# 应用环境配置
# ==============================

# 当前运行环境
# 可选值:
# development  开发环境
# staging      预发布环境
# production   生产环境
APP_ENV=development

# ==============================
# 日志配置
# ==============================

# 日志级别
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO


# ==============================
# 数据库配置
# ==============================

# 数据库连接字符串
# 格式:
# postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/mydb


# ==============================
# Redis配置
# ==============================

# Redis连接地址
REDIS_URL=redis://localhost:6379/0

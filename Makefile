# Makefile 用于统一开发命令
# 可以避免每次输入很长的命令


# ==============================
# 安装依赖
# ==============================
install:
	poetry install


# ==============================
# 启动应用
# ==============================
run:
	poetry run python src/cmdb_watch/manage.py runserver


# ==============================
# 代码格式化
# ==============================
format:
	poetry run black .


# ==============================
# 代码检查
# ==============================
lint:
	poetry run ruff check .


# ==============================
# 运行测试
# ==============================
test:
	poetry run pytest


# ==============================
# 运行所有 pre-commit 检查
# ==============================
precommit:
	pre-commit run --all-files